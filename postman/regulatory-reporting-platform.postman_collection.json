        {
          "name": "List processing jobs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();\r",
                  "\r",
                  "pm.test('returns 200 OK', function () {\r",
                  "  pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test('returns a list', function () {\r",
                  "  pm.expect(response).to.be.an('array');\r",
                  "});\r",
                  "\r",
                  "pm.test('each job has required fields', function () {\r",
                  "  response.forEach((job) => {\r",
                  "    pm.expect(job).to.have.property('jobId');\r",
                  "    pm.expect(job).to.have.property('fileId');\r",
                  "    pm.expect(job).to.have.property('originalFilename');\r",
                  "    pm.expect(job).to.have.property('fileStatus');\r",
                  "    pm.expect(job).to.have.property('jobStatus');\r",
                  "    pm.expect(job).to.have.property('message');\r",
                  "    pm.expect(job).to.have.property('uploadedBy');\r",
                  "    pm.expect(job).to.have.property('createdAt');\r",
                  "  });\r",
                  "});\r",
                  "\r",
                  "pm.test('job statuses are valid', function () {\r",
                  "  const validStatuses = [\r",
                  "    'PENDING_EXECUTION',\r",
                  "    'PROCESSING',\r",
                  "    'PROCESSING_FAILED',\r",
                  "    'AWAITING_APPROVAL',\r",
                  "    'APPROVED',\r",
                  "    'REJECTED',\r",
                  "    'REVOKED'\r",
                  "  ];\r",
                  "\r",
                  "  response.forEach((job) => {\r",
                  "    pm.expect(validStatuses).to.include(job.jobStatus);\r",
                  "  });\r",
                  "});\r",
                  "\r",
                  "pm.test('file statuses are valid', function () {\r",
                  "  const validFileStatuses = ['STORED', 'MISSING', 'FAILED', 'DELETED'];\r",
                  "\r",
                  "  response.forEach((job) => {\r",
                  "    pm.expect(validFileStatuses).to.include(job.fileStatus);\r",
                  "  });\r",
                  "});\r",
                  "\r",
                  "if (response.length > 0) {\r",
                  "  pm.collectionVariables.set('jobId', response[0].jobId);\r",
                  "  pm.collectionVariables.set('processingJobFileId', response[0].fileId);\r",
                  "}\r",
                  "\r",
                  ""
                ],
