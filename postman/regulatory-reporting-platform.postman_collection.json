    {
      "name": "Report Files",
      "item": [
        {
          "name": "List files by analyst01",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "pm.test('returns 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('returns a list', () => pm.expect(response).to.be.an('array'));",
                  "pm.test('file statuses are valid', () => {",
                  "  const valid = ['STORED', 'MISSING', 'FAILED', 'DELETED'];",
                  "  response.forEach(file => pm.expect(valid).to.include(file.fileStatus));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/report-files?username=analyst01"
          }
        },
