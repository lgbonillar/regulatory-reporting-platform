			"name": "Report Files",
			"item": [
				{
					"name": "Upload report file",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"",
									"pm.collectionVariables.set('fileId', response.fileId);",
									"pm.collectionVariables.set('jobId', response.jobId);",
									"",
									"pm.test('returns 200 OK', function () {",
									"  pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('creates file and processing job', function () {",
									"  pm.expect(response.fileId).to.exist;",
									"  pm.expect(response.jobId).to.exist;",
									"  pm.expect(response.status).to.eql('PENDING');",
									"});",
									""
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
