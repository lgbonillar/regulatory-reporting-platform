        {
          "name": "List report files by username",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();\r",
                  "const fileId = pm.collectionVariables.get('fileId');\r",
                  "const username = pm.environment.get('username');\r",
                  "\r",
                  "pm.test('returns 200 OK', function () {\r",
                  "  pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test('returns a list', function () {\r",
                  "  pm.expect(response).to.be.an('array');\r",
                  "});\r",
                  "\r",
                  "pm.test('includes uploaded file', function () {\r",
                  "  const uploadedFile = response.find((file) => file.fileId === fileId);\r",
                  "\r",
                  "  pm.expect(uploadedFile, `Expected list to include fileId ${fileId}`).to.exist;\r",
                  "  pm.expect(uploadedFile.fileStatus).to.eql('STORED');\r",
                  "  pm.expect(uploadedFile.uploadedBy).to.eql(username);\r",
                  "});\r",
                  "\r",
                  "pm.test('file statuses are valid and visible', function () {\r",
                  "  const visibleFileStatuses = ['STORED', 'MISSING', 'FAILED'];\r",
                  "\r",
                  "  response.forEach((file) => {\r",
                  "    pm.expect(visibleFileStatuses).to.include(file.fileStatus);\r",
                  "  });\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
