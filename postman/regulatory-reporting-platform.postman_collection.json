  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login - current user",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "pm.test('returns 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('returns tokens', () => {",
                  "  pm.expect(response.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(response.refreshToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(response.tokenType).to.eql('Bearer');",
                  "});",
                  "pm.environment.set('accessToken', response.accessToken);",
                  "pm.environment.set('refreshToken', response.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
