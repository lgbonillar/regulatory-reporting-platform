    {
      "name": "Processing Jobs",
      "item": [
        {
          "name": "List all processing jobs",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "pm.test('returns 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('returns a list', () => pm.expect(response).to.be.an('array'));",
                  "pm.test('job statuses are valid', () => {",
                  "  const valid = ['PENDING_EXECUTION', 'PROCESSING', 'PROCESSING_FAILED', 'AWAITING_APPROVAL', 'APPROVED', 'REJECTED', 'REVOKED'];",
                  "  response.forEach(job => pm.expect(valid).to.include(job.jobStatus));",
                  "});",
                  "if (response.length > 0) {",
                  "  pm.collectionVariables.set('jobId', response[0].jobId);",
                  "  pm.collectionVariables.set('fileId', response[0].fileId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/processing-jobs"
          }
