        {
          "name": "Upload report file",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "pm.test('returns 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('returns upload response', function () {",
                  "  pm.expect(response.fileId).to.be.a('string');",
                  "  pm.expect(response.jobId).to.be.a('string');",
                  "  pm.expect(response.originalFilename).to.be.a('string');",
                  "  pm.expect(response.jobStatus).to.eql('PENDING_EXECUTION');",
                  "  pm.expect(response.fileStatus).to.eql('STORED');",
                  "  pm.expect(response.message).to.eql('File uploaded successfully');",
                  "});",
                  "",
                  "pm.collectionVariables.set('fileId', response.fileId);",
                  "pm.collectionVariables.set('jobId', response.jobId);",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "protocolProfileBehavior": {
            "disabledSystemHeaders": {}
          },
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
